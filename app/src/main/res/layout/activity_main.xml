<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        tools:context=".MainActivity">

        <com.example.ocr.CropImageView
            android:id="@+id/cropImageView"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:scaleType="fitCenter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btnLoad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Load"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cropImageView" android:textSize="11sp"
            android:minHeight="48dp" />
            
        <Button
            android:id="@+id/btnResetImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Reset Image"
            app:layout_constraintStart_toEndOf="@+id/btnLoad"
            app:layout_constraintTop_toTopOf="@+id/btnLoad" android:textSize="11sp"
            android:minHeight="48dp" />

        <CheckBox
            android:id="@+id/cbCrop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crop Rect"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnLoad" android:textSize="11sp" />

        <Button
            android:id="@+id/btnApplyCrop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Do Crop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/cbCrop"
            app:layout_constraintBottom_toBottomOf="@+id/cbCrop" android:textSize="11sp"
            android:minHeight="48dp" />

        <!-- CLAHE -->
        <TextView
            android:id="@+id/tvClahe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLAHE Clip Limit:"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cbCrop" android:textSize="11sp" />
            
        <EditText
            android:id="@+id/etClaheLimit"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:text="2.0"
            app:layout_constraintStart_toEndOf="@+id/tvClahe"
            app:layout_constraintTop_toTopOf="@+id/tvClahe"
            app:layout_constraintBottom_toBottomOf="@+id/tvClahe" android:textSize="11sp" />
            
        <Button
            android:id="@+id/btnApplyClahe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apply CLAHE"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvClahe"
            app:layout_constraintBottom_toBottomOf="@+id/tvClahe" android:textSize="11sp"
            android:minHeight="48dp" />

        <LinearLayout
            android:id="@+id/llAligner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnApplyClahe">
            
            <Button
                android:id="@+id/btnFindQR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Find QR" android:textSize="11sp"
            android:minHeight="48dp" />

            <Button
                android:id="@+id/btnWarpQR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Warp QR" android:textSize="11sp"
            android:minHeight="48dp" />
        </LinearLayout>

        <!-- Threshold -->
        <Spinner
            android:id="@+id/spinnerThresh"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/llAligner" />

        <EditText
            android:id="@+id/etBlockSize"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="51"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@+id/spinnerThresh"
            app:layout_constraintTop_toTopOf="@+id/spinnerThresh"
            app:layout_constraintBottom_toBottomOf="@+id/spinnerThresh" android:textSize="11sp" />

        <Button
            android:id="@+id/btnApplyThresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apply Thresh"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/spinnerThresh"
            app:layout_constraintBottom_toBottomOf="@+id/spinnerThresh" android:textSize="11sp"
            android:minHeight="48dp" />

        <!-- Morphology -->
        <Spinner
            android:id="@+id/spinnerMorph"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/spinnerThresh" />

        <EditText
            android:id="@+id/etMorphKernel"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="3"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@+id/spinnerMorph"
            app:layout_constraintTop_toTopOf="@+id/spinnerMorph"
            app:layout_constraintBottom_toBottomOf="@+id/spinnerMorph"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnApplyMorph"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apply Morph"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/spinnerMorph"
            app:layout_constraintBottom_toBottomOf="@+id/spinnerMorph"
            android:textSize="11sp"
            android:minHeight="48dp" />

        <!-- Reconstruct -->
        <Button
            android:id="@+id/btnApplyReconstruct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI-Like Digital Reconstruct"
            android:textSize="11sp"
            android:minHeight="48dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/spinnerMorph" />

        <!-- All -->
        <Button
            android:id="@+id/btnApplyAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply Pipeline (All Checked Steps)"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/btnApplyReconstruct"
            android:textSize="11sp"
            android:minHeight="48dp" />

        <View
            android:id="@+id/separator"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/btnApplyAll" />

        <Spinner
            android:id="@+id/spinnerLibrary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:entries="@array/ocr_libraries"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btnTest"
            app:layout_constraintTop_toBottomOf="@+id/separator"
            app:layout_constraintBottom_toBottomOf="@+id/btnTest" />

        <Button
            android:id="@+id/btnTest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/test_image"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@+id/spinnerLibrary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/separator" android:textSize="11sp"
            android:minHeight="48dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/result_text"
            
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/btnTest" android:textSize="11sp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
